# Run: from a gno checkout:
# gh pr checkout 5985 -R gnolang/gno && git checkout 639f73fb3
# curl -fsSL -o gnovm/cmd/gno/testdata/test/flag_x.txtar \
#   https://raw.githubusercontent.com/samouraiworld/gno-agent-workspace/main/reviews/pr/5xxx/5985-x-flag-run-test/1-639f73fb3/tests/flag_x.txtar
# go test -v -run 'Test_Scripts/test/flag_x$' ./gnovm/cmd/gno/
# rm gnovm/cmd/gno/testdata/test/flag_x.txtar
#
# Covers the mempackage patch loop in gnovm/cmd/gno/test.go, which no test
# reaches at 639f73fb3: run_test.go only exercises `gno run -X`.
# Passes at the pinned hash; it is coverage, not a bug repro.

# gno test -X overrides a package-level string var in the package under test.

gno test -v -X Version=1.2.3 .

stdout 'version=1.2.3'
stderr '--- PASS: TestVersion'

# without -X the declared default is used.

gno test -v .

stdout 'version=dev'

-- flag_x.gno --
package flag_x

var Version = "dev"

func V() string { return Version }

-- flag_x_test.gno --
package flag_x

import "testing"

func TestVersion(t *testing.T) {
	println("version=" + V())
}

-- gnomod.toml --
module = 'gno.test/r/integ/flag_x'
